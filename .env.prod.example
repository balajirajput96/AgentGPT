# Platform Config: (max loops determines how many times the agent may execute)
NEXT_PUBLIC_MAX_LOOPS="100"
REWORKD_PLATFORM_MAX_LOOPS=${NEXT_PUBLIC_MAX_LOOPS}

# Deployment Environment:
NODE_ENV="production"
NEXT_PUBLIC_VERCEL_ENV="production"

# NextJS:
NEXT_PUBLIC_BACKEND_URL="http://your-domain.com:8000"

# Next Auth config:
NEXTAUTH_SECRET=your-secure-secret-here-generate-using-openssl-rand-base64-32
NEXTAUTH_URL="http://your-domain.com:3000"

# Auth providers (Use if you want to get out of development mode sign-in):
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_CLIENT_ID="your-discord-client-id"

# Backend:
REWORKD_PLATFORM_ENVIRONMENT="production"
REWORKD_PLATFORM_FF_MOCK_MODE_ENABLED="false"
REWORKD_PLATFORM_OPENAI_API_KEY="your-openai-api-key"
REWORKD_PLATFORM_FRONTEND_URL="http://your-domain.com:3000"
REWORKD_PLATFORM_RELOAD="false"
REWORKD_PLATFORM_OPENAI_API_BASE="https://api.openai.com/v1"
REWORKD_PLATFORM_SERP_API_KEY="your-serp-api-key"
REWORKD_PLATFORM_REPLICATE_API_KEY="your-replicate-api-key"
REWORKD_PLATFORM_SID_CLIENT_ID="your-sid-client-id"
REWORKD_PLATFORM_SID_CLIENT_SECRET="your-sid-client-secret"
REWORKD_PLATFORM_SID_REDIRECT_URI="http://your-domain.com:8000/api/auth/sid/callback"

# Database (Backend):
REWORKD_PLATFORM_DATABASE_USER="reworkd_platform"
REWORKD_PLATFORM_DATABASE_PASSWORD="your-secure-database-password"
REWORKD_PLATFORM_DATABASE_HOST="agentgpt_db"
REWORKD_PLATFORM_DATABASE_PORT="3307"
REWORKD_PLATFORM_DATABASE_NAME="reworkd_platform"
REWORKD_PLATFORM_DATABASE_URL="mysql://${REWORKD_PLATFORM_DATABASE_USER}:${REWORKD_PLATFORM_DATABASE_PASSWORD}@${REWORKD_PLATFORM_DATABASE_HOST}:${REWORKD_PLATFORM_DATABASE_PORT}/${REWORKD_PLATFORM_DATABASE_NAME}"

# Database (Frontend):
DATABASE_USER="reworkd_platform"
DATABASE_PASSWORD="your-secure-database-password"
DATABASE_HOST="agentgpt_db"
DATABASE_PORT="3307"
DATABASE_NAME="reworkd_platform"
DATABASE_URL="mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"
